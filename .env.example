# Atelier — Required Environment Variables

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# AI Providers
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SCORING_MODEL=claude-sonnet-4-20250514
# Legacy fallback (used if CHAT/SCORING not set)
ANTHROPIC_MODEL=claude-sonnet-4-20250514
DEFAULT_PROVIDER=anthropic

# Optional: OpenAI (if using dual-provider mode)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.4

# MCP StayPortal — Supabase credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
STAYPORTAL_EMAIL=your-email@example.com
STAYPORTAL_PASSWORD=your-password

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars-here
ALLOW_REGISTRATION=false

# CORS (comma-separated origins, or * for dev)
CORS_ORIGIN=*

# SMS Provider (Pling / Front Information AS)
PLING_SERVICE_ID=your-service-id
PLING_USERNAME=your-username
PLING_PASSWORD=your-password

# SMS Simulator (Rova virtual phone)
SMS_CHANNEL_MODE=simulator
SIMULATOR_WEBHOOK_URL=https://your-rova-url/api/sms/simulator
SIMULATOR_SECRET=your-shared-simulator-secret
SMS_MAX_CHARS=320
SIMULATOR_AUTO_REPLY=true
SMS_REPLY_DELAY_S=30
SMS_REPLY_MAX_WAIT_S=120

# Calendly
CALENDLY_URL=https://calendly.com/leasing-stay/15min

# Video Tour (set per listing or globally)
# VIDEO_TOUR_URL=https://example.com/tour

# Webhooks
WEBHOOK_SECRET=your-hmac-webhook-secret

# Server
HOST=0.0.0.0
PORT=3001
NODE_ENV=development
